      "name": "tagged-read-call",
      "input": "<pi_tool_call>\n{\"name\":\"read\",\"arguments\":{\"path\":\"package.json\"}}\n</pi_tool_call>",
      "expect": {
        "kind": "tool_call",
        "name": "read",
        "arguments": {
          "path": "package.json"
        }
      }
    },
    {
      "name": "attributed-tag-read-call",
      "input": "<pi_tool_call name=\"read\">\n{\"path\":\"package.json\"}\n</pi_tool_call>",
      "expect": {
        "kind": "tool_call",
        "name": "read",
        "arguments": {
          "path": "package.json"
        },
        "warningsContain": [
          "attributed pi_tool_call"
        ]
      }
    },
    {
      "name": "loose-name-arguments-windows-path-call",
      "input": "<pi_tool_call>\nname: \"read\"\narguments: {\"path\":\"D:\\codeproject\\data-etl\\main.py\", \"offset\":1, \"limit\":30}\n</pi_tool_call>",
      "expect": {
        "kind": "tool_call",
        "name": "read",
        "arguments": {
          "path": "D:\\codeproject\\data-etl\\main.py",
          "offset": 1,
          "limit": 30
        },
        "warningsContain": [
          "loose name/arguments",
          "Windows path backslashes"
        ]
      }
    },
    {
