{
  "parser": [
    {
      "name": "tagged-read-call",
      "input": "<pi_tool_call>\n{\"name\":\"read\",\"arguments\":{\"path\":\"package.json\"}}\n</pi_tool_call>",
      "expect": {
        "kind": "tool_call",
        "name": "read",
        "arguments": {
          "path": "package.json"
        }
      }
    },
    {
      "name": "attributed-tag-read-call",
      "input": "<pi_tool_call name=\"read\">\n{\"path\":\"package.json\"}\n</pi_tool_call>",
      "expect": {
        "kind": "tool_call",
        "name": "read",
        "arguments": {
          "path": "package.json"
        },
        "warningsContain": [
          "attributed pi_tool_call"
        ]
      }
    },
    {
      "name": "bare-json-call",
      "input": "{\"name\":\"bash\",\"arguments\":{\"command\":\"pwd\"}}",
      "expect": {
        "kind": "tool_call",
        "name": "bash",
        "arguments": {
          "command": "pwd"
        },
        "warningsContain": [
          "accepted bare JSON"
        ]
      }
    },
    {
      "name": "surrounding-prose",
      "input": "I need one tool.\n<pi_tool_call>\n{\"name\":\"read\",\"arguments\":{\"path\":\"README.md\"}}\n</pi_tool_call>\nThen I will answer.",
      "expect": {
        "kind": "tool_call",
        "name": "read",
        "arguments": {
          "path": "README.md"
        },
        "before": "I need one tool.",
        "after": "Then I will answer.",
        "warningsContain": [
          "surrounding text"
        ]
      }
    },
    {
      "name": "function-style-call",
      "input": "fetch_content({\"url\":\"https://example.invalid\"})",
      "expect": {
        "kind": "error",
        "code": "function_style_tool_call"
      }
    },
    {
      "name": "raw-tool-history-markup",
      "input": "<pi_tool_call_history>\nid: call_1\nname: read\narguments: {\"path\":\"package.json\"}\n</pi_tool_call_history>",
      "expect": {
        "kind": "error",
        "code": "raw_protocol_markup"
      }
    },
    {
      "name": "neutral-tool-history-record",
      "input": "[previous_pi_tool_call]\nid: call_1\nname: read\narguments_json: {\"path\":\"package.json\"}\n[/previous_pi_tool_call]",
      "expect": {
        "kind": "error",
        "code": "raw_protocol_markup"
      }
    },
    {
      "name": "malformed-incomplete-tool-call-markup",
      "input": "I leaked a partial protocol tag:\n<pi_tool_call name=\"read\"\n{\"path\":\"package.json\"}",
      "expect": {
        "kind": "error",
        "code": "raw_protocol_markup"
      }
    },
    {
      "name": "multiple-tool-calls",
      "input": "<pi_tool_call>{\"name\":\"read\",\"arguments\":{}}</pi_tool_call><pi_tool_call>{\"name\":\"bash\",\"arguments\":{}}</pi_tool_call>",
      "expect": {
        "kind": "error",
        "code": "multiple_tool_calls"
      }
    },
    {
      "name": "unknown-top-level-field",
      "input": "<pi_tool_call>{\"name\":\"read\",\"arguments\":{},\"extra\":1}</pi_tool_call>",
      "expect": {
        "kind": "error",
        "code": "unknown_top_level_field"
      }
    }
  ],
  "providerReplay": [
    {
      "name": "bare-json-tool-call",
      "maxTools": 8,
      "context": {
        "systemPrompt": "system base",
        "tools": [
          {
            "name": "bash",
            "description": "Run a shell command",
            "parameters": {
              "type": "object",
              "properties": {
                "command": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "messages": [
          {
            "role": "user",
            "content": "run pwd"
          }
        ]
      },
      "responses": [
        {
          "content": "{\"name\":\"bash\",\"arguments\":{\"command\":\"pwd\"}}"
        }
      ],
      "expect": {
        "fetchCount": 1,
        "stopReason": "toolUse",
        "toolCalls": [
          {
            "name": "bash",
            "arguments": {
              "command": "pwd"
            }
          }
        ]
      }
    },
    {
      "name": "surrounding-prose-tool-call",
      "maxTools": 8,
      "context": {
        "systemPrompt": "system base",
        "tools": [
          {
            "name": "read",
            "description": "Read a file",
            "parameters": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "messages": [
          {
            "role": "user",
            "content": "read README.md"
          }
        ]
      },
      "responses": [
        {
          "content": "I will inspect it first.\n<pi_tool_call>\n{\"name\":\"read\",\"arguments\":{\"path\":\"README.md\"}}\n</pi_tool_call>\nThen I will summarize."
        }
      ],
      "expect": {
        "fetchCount": 1,
        "stopReason": "toolUse",
        "leadingTextIncludes": "inspect it",
        "trailingTextIncludes": "summarize",
        "toolCalls": [
          {
            "name": "read",
            "arguments": {
              "path": "README.md"
            }
          }
        ]
      }
    },
    {
      "name": "attributed-tag-tool-call",
      "maxTools": 8,
      "context": {
        "systemPrompt": "system base",
        "tools": [
          {
            "name": "read",
            "description": "Read a file",
            "parameters": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "messages": [
          {
            "role": "user",
            "content": "read package.json"
          }
        ]
      },
      "responses": [
        {
          "content": "<pi_tool_call name=\"read\">\n{\"path\":\"package.json\"}\n</pi_tool_call>"
        }
      ],
      "expect": {
        "fetchCount": 1,
        "stopReason": "toolUse",
        "toolCalls": [
          {
            "name": "read",
            "arguments": {
              "path": "package.json"
            }
          }
        ]
      }
    },
    {
      "name": "raw-tool-history-then-final",
      "maxTools": 8,
      "maxRepairRetries": 2,
      "maxTotalRecoveries": 4,
      "context": {
        "systemPrompt": "system base",
        "tools": [
          {
            "name": "read",
            "description": "Read a file",
            "parameters": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "messages": [
          {
            "role": "user",
            "content": "read package.json"
          }
        ]
      },
      "responses": [
        {
          "content": "<pi_tool_call_history>\nid: call_1\nname: read\narguments: {\"path\":\"package.json\"}\n</pi_tool_call_history>"
        },
        {
          "content": "Package summary is available without raw protocol markup."
        }
      ],
      "expect": {
        "fetchCount": 2,
        "stopReason": "stop",
        "leadingTextIncludes": "Package summary"
      }
    },
    {
      "name": "neutral-tool-history-then-final",
      "maxTools": 8,
      "maxRepairRetries": 2,
      "maxTotalRecoveries": 4,
      "context": {
        "systemPrompt": "system base",
        "tools": [
          {
            "name": "read",
            "description": "Read a file",
            "parameters": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "messages": [
          {
            "role": "user",
            "content": "read package.json"
          }
        ]
      },
      "responses": [
        {
          "content": "[previous_pi_tool_call]\nid: call_1\nname: read\narguments_json: {\"path\":\"package.json\"}\n[/previous_pi_tool_call]"
        },
        {
          "content": "Package summary is available without internal history records."
        }
      ],
      "expect": {
        "fetchCount": 2,
        "stopReason": "stop",
        "leadingTextIncludes": "Package summary"
      }
    },
    {
      "name": "malformed-protocol-markup-then-final",
      "maxTools": 8,
      "maxRepairRetries": 2,
      "maxTotalRecoveries": 4,
      "context": {
        "systemPrompt": "system base",
        "tools": [
          {
            "name": "read",
            "description": "Read a file",
            "parameters": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "messages": [
          {
            "role": "user",
            "content": "read package.json"
          }
        ]
      },
      "responses": [
        {
          "content": "<pi_tool_call name=\"read\"\n{\"path\":\"package.json\"}"
        },
        {
          "content": "Recovered from malformed protocol markup."
        }
      ],
      "expect": {
        "fetchCount": 2,
        "stopReason": "stop",
        "leadingTextIncludes": "Recovered from malformed"
      }
    },
    {
      "name": "bounded-schema-args-then-fixed",
      "maxTools": 8,
      "maxRepairRetries": 2,
      "maxTotalRecoveries": 4,
      "context": {
        "systemPrompt": "system base",
        "tools": [
          {
            "name": "bounded_read",
            "description": "Read one bounded file",
            "parameters": {
              "type": "object",
              "required": [
                "path",
                "limit"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 16,
                  "pattern": "^package\\.json$"
                },
                "limit": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5
                },
                "tags": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 2,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            }
          }
        ],
        "messages": [
          {
            "role": "user",
            "content": "bounded read package.json"
          }
        ]
      },
      "responses": [
        {
          "content": "<pi_tool_call>\n{\"name\":\"bounded_read\",\"arguments\":{\"path\":\"\",\"limit\":9,\"tags\":[],\"extra\":true}}\n</pi_tool_call>"
        },
        {
          "content": "<pi_tool_call>\n{\"name\":\"bounded_read\",\"arguments\":{\"path\":\"package.json\",\"limit\":5,\"tags\":[\"pkg\"]}}\n</pi_tool_call>"
        }
      ],
      "expect": {
        "fetchCount": 2,
        "stopReason": "toolUse",
        "toolCalls": [
          {
            "name": "bounded_read",
            "arguments": {
              "path": "package.json",
              "limit": 5,
              "tags": [
                "pkg"
              ]
            }
          }
        ]
      }
    },
    {
      "name": "unknown-hidden-tool-then-selected-tool",
      "maxTools": 1,
      "maxRepairRetries": 2,
      "maxTotalRecoveries": 4,
      "context": {
        "systemPrompt": "system base",
        "tools": [
          {
            "name": "read",
            "description": "Read a file",
            "parameters": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                }
              }
            }
          },
          {
            "name": "hidden_admin",
            "description": "Hidden admin tool",
            "parameters": {
              "type": "object",
              "properties": {}
            }
          }
        ],
        "messages": [
          {
            "role": "user",
            "content": "read package.json"
          }
        ]
      },
      "responses": [
        {
          "content": "<pi_tool_call>\n{\"name\":\"hidden_admin\",\"arguments\":{\"action\":\"dump\"}}\n</pi_tool_call>"
        },
        {
          "content": "<pi_tool_call>\n{\"name\":\"read\",\"arguments\":{\"path\":\"package.json\"}}\n</pi_tool_call>"
        }
      ],
      "expect": {
        "fetchCount": 2,
        "stopReason": "toolUse",
        "toolCalls": [
          {
            "name": "read",
            "arguments": {
              "path": "package.json"
            }
          }
        ]
      }
    }
  ]
}
