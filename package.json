{
  "name": "pi-extensions",
  "version": "0.13.0",
  "private": true,
  "scripts": {
    "check:prompt-governance": "node scripts/pi67-prompt-governance-check.mjs",
    "typecheck:xtalpi": "node npm/node_modules/typescript/bin/tsc --project tsconfig.xtalpi.json --pretty false",
    "typecheck:hy-memory": "node npm/node_modules/typescript/bin/tsc --project tsconfig.hy-memory.json --pretty false",
    "test:xtalpi": "bash scripts/pi67-test-xtalpi-pi-tools.sh",
    "test:xtalpi:node": "node --no-warnings --test \"tests/xtalpi-pi-tools/**/*.test.mjs\"",
    "test:xtalpi:coverage": "node --no-warnings --test --experimental-test-coverage --test-coverage-lines=93 --test-coverage-branches=85 --test-coverage-functions=95 \"tests/xtalpi-pi-tools/**/*.test.mjs\"",
    "test:hy-memory": "node --no-warnings --test \"tests/pi-hy-memory/**/*.test.mjs\""
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@feniix/pi-sequential-thinking": "^5.0.2",
    "@ff-labs/pi-fff": "^0.9.6",
    "@juicesharp/rpiv-advisor": "^1.20.0",
    "@juicesharp/rpiv-ask-user-question": "^1.20.0",
    "@narumitw/pi-btw": "^0.11.0",
    "@narumitw/pi-plan-mode": "^0.11.0",
    "@victor-software-house/pi-curated-themes": "^0.2.1",
    "pi-markdown-preview": "^0.10.0",
    "pi-mcp-adapter": "^2.10.0",
    "pi-observational-memory": "^3.0.2",
    "pi-rewind": "^0.5.0",
    "pi-simplify": "^0.2.2",
    "pi-smart-fetch": "^0.3.12",
    "pi-subagents": "^0.34.0",
    "pi-until-done": "^0.2.2",
    "pi-web-access": "^0.13.0"
  }
}
